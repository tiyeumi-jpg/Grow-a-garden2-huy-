-- PHẦN MENU CHÍNH (ĐỂ GỌI SAU KHI XÁC THỰC KEY)
local function StartMainScript()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({Name = "ib.Tiktok.huyz367 - Main Menu", LoadingTitle = "Loading...", LoadingSubtitle = "by Bé"})

    local Tab = Window:CreateTab("ESP & Aimbot", nil)
    _G.ESP = false _G.Skel = false _G.Aimbot = false _G.AOVSize = 300
    
    Tab:CreateToggle({Name = "Box & Line ESP", Callback = function(v) _G.ESP = v end})
    Tab:CreateToggle({Name = "Skeleton ESP", Callback = function(v) _G.Skel = v end})
    Tab:CreateToggle({Name = "Aimbot (Lock Head)", Callback = function(v) _G.Aimbot = v end})
    Tab:CreateSlider({Name = "Kích thước vòng AOV", Range = {50, 800}, Increment = 10, Suffix = "px", CurrentValue = 300, Callback = function(v) _G.AOVSize = v end})

    local FarmTab = Window:CreateTab("Script Trồng Cây 🌲", nil)
    FarmTab:CreateButton({Name = "Chạy Script Trồng Cây (vipbro)", Callback = function()
        _G.AutoTranslate = false
        _G.SaveConfig = true
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Dev-BlueX/BlueX-Hub/refs/heads/main/Main.lua"))()
        Rayfield:Notify({Title = "Thông báo", Content = "Đã kích hoạt script VIPBRO!", Duration = 3})
    end})

    -- Nút NET
    local gui = Instance.new("ScreenGui", game.CoreGui)
    local btn = Instance.new("TextButton", gui)
    btn.Size = UDim2.new(0, 80, 0, 80) btn.Position = UDim2.new(0.5, -40, 0.5, -40)
    btn.Text = "NET" btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0) btn.Draggable = true
    
    local isOn = false
    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        btn.Text = isOn and "ON" or "NET"
        for _, other in pairs(Players:GetPlayers()) do
            if other ~= LP and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
                other.Character.HumanoidRootPart.Anchored = isOn
            end
        end
    end)

    -- Logic ESP & Aimbot
    local AOV = Drawing.new("Circle")
    AOV.Color = Color3.fromRGB(255, 255, 255); AOV.Thickness = 2; AOV.Filled = false; AOV.Visible = true
    local drawings = {}
    RunService.RenderStepped:Connect(function()
        AOV.Radius = _G.AOVSize; AOV.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2); AOV.Visible = _G.Aimbot
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character and p.Character:FindFirstChild("Head") then
                if not drawings[p.Name] then drawings[p.Name] = {Line = Drawing.new("Line")} end
                local pos, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
                drawings[p.Name].Line.From = Vector2.new(Camera.ViewportSize.X/2, 0); drawings[p.Name].Line.To = Vector2.new(pos.X, pos.Y); drawings[p.Name].Line.Visible = _G.ESP and on
            end
        end
        if _G.Aimbot then
            local closest = nil; local minD = _G.AOVSize; local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local headPos, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
                    local dist = (Vector2.new(headPos.X, headPos.Y) - center).Magnitude
                    if dist < minD then minD = dist; closest = p.Character.Head end
                end
            end
            if closest then Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, closest.Position) end
        end
    end)
end

