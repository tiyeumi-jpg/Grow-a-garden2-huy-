-- PHẦN MENU CHÍNH
local function StartMainScript()
    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({Name = "ib.Tiktok.huyz367 - Main Menu", LoadingTitle = "Loading...", LoadingSubtitle = "by Bé"})
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LP = Players.LocalPlayer
    local Camera = workspace.CurrentCamera

    -- Tab ESP & Aimbot
    local Tab = Window:CreateTab("ESP & Aimbot", nil)
    _G.ESP = false _G.Skel = false _G.Aimbot = false
    _G.AOVSize = 300
    
    Tab:CreateToggle({Name = "Box & Line ESP", Callback = function(v) _G.ESP = v end})
    Tab:CreateToggle({Name = "Skeleton ESP", Callback = function(v) _G.Skel = v end})
    Tab:CreateToggle({Name = "Aimbot (Lock Head)", Callback = function(v) _G.Aimbot = v end})
    
    Tab:CreateSlider({
        Name = "Kích thước vòng AOV",
        Range = {50, 800},
        Increment = 10,
        Suffix = "px",
        CurrentValue = 300,
        Callback = function(v) _G.AOVSize = v end
    })

    -- Tab Trồng Cây 🌲
    local FarmTab = Window:CreateTab("Script Trồng Cây 🌲", nil)
    FarmTab:CreateButton({
        Name = "Chạy Script Trồng Cây",
        Callback = function()
            repeat task.wait() until game:IsLoaded() and game:GetService("Players") and game.Players.LocalPlayer and game.Players.LocalPlayer:FindFirstChild("PlayerGui")
            loadstring(game:HttpGet("https://raw.githubusercontent.com/Teddyseetink/Haidepzai/refs/heads/main/main.lua"))()
            Rayfield:Notify({Title = "Thông báo", Content = "Đã kích hoạt script trồng cây!", Duration = 3})
        end
    })

    -- Nút NET
    local gui = Instance.new("ScreenGui", game.CoreGui)
    local btn = Instance.new("TextButton", gui)
    btn.Size = UDim2.new(0, 80, 0, 80) btn.Position = UDim2.new(0.5, -40, 0.5, -40)
    btn.Text = "NET" btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0) btn.Draggable = true
    
    local isOn = false
    btn.MouseButton1Click:Connect(function()
        isOn = not isOn
        btn.Text = isOn and "ON" or "NET"
        for _, other in pairs(Players:GetPlayers()) do
            if other ~= LP and other.Character and other.Character:FindFirstChild("HumanoidRootPart") then
                other.Character.HumanoidRootPart.Anchored = isOn
            end
        end
    end)

    -- Vòng tròn AOV
    local AOV = Drawing.new("Circle")
    AOV.Color = Color3.fromRGB(255, 255, 255)
    AOV.Thickness = 2
    AOV.Filled = false
    AOV.Visible = true

    -- Logic ESP Vẽ & Aimbot
    local drawings = {}
    RunService.RenderStepped:Connect(function()
        -- Cập nhật AOV
        AOV.Radius = _G.AOVSize
        AOV.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        AOV.Visible = _G.Aimbot

        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LP and p.Character and p.Character:FindFirstChild("Head") then
                if not drawings[p.Name] then drawings[p.Name] = {Line = Drawing.new("Line"), Box = Drawing.new("Square")} end
                local pos, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
                if _G.ESP then
                    drawings[p.Name].Line.From = Vector2.new(Camera.ViewportSize.X/2, 0)
                    drawings[p.Name].Line.To = Vector2.new(pos.X, pos.Y)
                    drawings[p.Name].Line.Visible = true
                else
                    drawings[p.Name].Line.Visible = false
                end
            end
        end
        
        -- Logic Aimbot với giới hạn AOV
        if _G.Aimbot then
            local closest = nil
            local minDistance = _G.AOVSize
            local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("Head") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local headPos, on = Camera:WorldToViewportPoint(p.Character.Head.Position)
                    local distanceToCenter = (Vector2.new(headPos.X, headPos.Y) - screenCenter).Magnitude
                    if distanceToCenter < minDistance then
                        minDistance = distanceToCenter
                        closest = p.Character.Head
                    end
                end
            end
            if closest then 
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, closest.Position) 
            end
        end
    end)
end

